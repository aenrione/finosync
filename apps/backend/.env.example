# Rails Configuration
RAILS_ENV=development
RAILS_MASTER_KEY=your-master-key-here

# Database (SQLite in development)
# No configuration needed for SQLite

# Server
PORT=3000

# CORS Configuration
# In development, allows all origins
# In production, set specific allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Fintoc Integration (Chilean Bank Aggregation)
# Get your API key from: https://fintoc.com
# FINTOC_SECRET_KEY is the company-wide secret (backend only, never exposed to client)
# FINTOC_API_KEY is the public key used only to initialize the Fintoc widget on mobile
FINTOC_API_KEY=your_fintoc_api_key_here
FINTOC_SECRET_KEY=your_fintoc_secret_key_here

# Active Record Encryption (for encrypting link_token / primary_key at rest)
# Generate with: bundle exec rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=your_ar_encryption_primary_key
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=your_ar_encryption_deterministic_key
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=your_ar_encryption_key_derivation_salt
