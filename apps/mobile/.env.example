# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000

# Environment
EXPO_PUBLIC_ENV=development

# Feature Flags (optional)
EXPO_PUBLIC_ENABLE_BIOMETRIC_AUTH=false
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=false

# Sentry (Error Tracking) - Optional
# SENTRY_DSN=your_sentry_dsn_here

# Fintoc (Banking Integration)
# Get your public key from https://app.fintoc.com/dashboard
EXPO_PUBLIC_FINTOC_PUBLIC_KEY=pk_live_your_key_here

# Google Services (if needed for authentication)
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
